    def open_comments(self, post, cmt_btn, viewer, WHITE, LIGHT, GRAY, DGRAY, PINK,
                      refresh_activity_fn):
        win = tk.Toplevel(self.root)
        win.title("Komentar")
        win.geometry("420x440")
        win.config(bg=WHITE)
        tk.Label(win, text="Komentar", font=("Segoe UI", 13, "bold"), bg=WHITE).pack(pady=10)

        lf = tk.Frame(win, bg=WHITE)
        lf.pack(fill="both", expand=True, padx=16)
        _, c_inner = self.make_scrollable(lf, WHITE)

        def render_comments():
            for w in c_inner.winfo_children():
                w.destroy()
            if not post.get("comments"):
                tk.Label(c_inner, text="Belum ada komentar.",
                         bg=WHITE, fg=GRAY, font=("Segoe UI", 9)).pack(pady=10)
                return
            for cm in post["comments"]:
                row = tk.Frame(c_inner, bg=LIGHT, pady=6, padx=8,
                               highlightthickness=1, highlightbackground="#eee")
                row.pack(fill="x", pady=2)
                tk.Label(row, text=f"@{cm['username']}  •  {cm['ts']}",
                         font=("Segoe UI", 8), bg=LIGHT, fg=GRAY).pack(anchor="w")
                tk.Label(row, text=cm["text"], font=("Segoe UI", 10),
                         bg=LIGHT, wraplength=340, justify="left").pack(anchor="w")
                if cm["username"] == viewer["username"]:
                    def make_del(cid=cm["id"]):
                        def do():
                            post["comments"] = [x for x in post["comments"] if x["id"] != cid]
                            render_comments()
                            cmt_btn.config(text=f"💬 {len(post.get('comments', []))}")
                            refresh_activity_fn()
                        return do
                    tk.Button(row, text="Hapus", bg="tomato", fg="white",
                              font=("Segoe UI", 7), bd=0, padx=4,
                              command=make_del()).pack(anchor="e")

        render_comments()

        bottom = tk.Frame(win, bg=WHITE)
        bottom.pack(fill="x", padx=16, pady=8)

        cmt_input = tk.Entry(bottom, font=("Segoe UI", 10), bd=1, relief="solid")
        cmt_input.pack(side="left", fill="x", expand=True, ipady=4)
        self.add_placeholder(cmt_input, "Tulis komentar...")

        def post_comment():
            text = self.get_entry_value(cmt_input)
            if not text:
                return
            filtered, words = self.content_filter(text)
            if words:
                self.log_violation(viewer["username"], words, "Komentar")
            post.setdefault("comments", []).append({
                "id":       self.next_comment_id,
                "username": viewer["username"],
                "text":     filtered,
                "ts":       self.now_str(),
            })
            self.next_comment_id += 1
            cmt_input.delete(0, tk.END)
            cmt_input.is_showing_placeholder = False
            render_comments()
            cmt_btn.config(text=f"💬 {len(post.get('comments', []))}")
            refresh_activity_fn()

        tk.Button(bottom, text="Kirim", bg="#ffc0cb",
                  font=("Segoe UI", 9, "bold"), bd=0, padx=10,
                  command=post_comment).pack(side="left", padx=(6, 0))

