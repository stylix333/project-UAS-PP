    def _render_profile(self, parent, user, LIGHT, DGRAY, GRAY, PINK, WHITE):
        for w in parent.winfo_children():
            w.destroy()

        av = tk.Frame(parent, bg=LIGHT)
        av.pack(pady=20)
        initials = "".join(w[0].upper() for w in user["fullname"].split()[:2])
        tk.Label(av, text=initials, font=("Segoe UI", 22, "bold"),
                 bg=PINK, fg=DGRAY, width=3, height=1).pack()

        tk.Label(parent, text=user["fullname"], font=("Segoe UI", 14, "bold"),
                 bg=LIGHT, fg=DGRAY).pack()
        tk.Label(parent, text=f"@{user['username']}", font=("Segoe UI", 10),
                 bg=LIGHT, fg=GRAY).pack(pady=2)
        tk.Label(parent, text=user["email"], font=("Segoe UI", 10),
                 bg=LIGHT, fg=GRAY).pack()
        bio = user.get("bio", "") or "Belum ada bio"
        tk.Label(parent, text=bio, font=("Segoe UI", 9, "italic"),
                 bg=LIGHT, fg=GRAY).pack(pady=4)

        stats_frame = tk.Frame(parent, bg=LIGHT)
        stats_frame.pack(pady=6)
        user_posts   = [p for p in self.posts   if p["username"] == user["username"]]
        user_stories = [s for s in self.stories if s["username"] == user["username"]]
        following_count  = len(self.follows.get(user["username"], set()))
        followers_count  = sum(1 for f in self.follows.values() if user["username"] in f)
        for label, val in [("Post", len(user_posts)), ("Story", len(user_stories)),
                            ("Following", following_count), ("Followers", followers_count)]:
            box = tk.Frame(stats_frame, bg=WHITE, width=75, height=52,
                           highlightthickness=1, highlightbackground="#ddd")
            box.pack(side="left", padx=6)
            box.pack_propagate(False)
            tk.Label(box, text=str(val), font=("Segoe UI", 15, "bold"),
                     bg=WHITE, fg="#e57a8a").pack(expand=True)
            tk.Label(box, text=label, font=("Segoe UI", 7), bg=WHITE, fg=GRAY).pack()

        tk.Frame(parent, bg="#eeeeee", height=1).pack(fill="x", padx=40, pady=10)

        btn_row = tk.Frame(parent, bg=LIGHT)
        btn_row.pack()
        tk.Button(btn_row, text="  Edit Profil  ", font=("Segoe UI", 10),
                  bg=PINK, fg=DGRAY, bd=0, relief="flat", padx=12, pady=6, cursor="hand2",
                  command=lambda: self.open_edit_profile(
                      user, parent, LIGHT, DGRAY, GRAY, PINK, WHITE)).pack(side="left", padx=4)
        tk.Button(btn_row, text="  👥 Connect  ", font=("Segoe UI", 10),
                  bg=LIGHT, fg=DGRAY, bd=1, relief="solid", padx=12, pady=6, cursor="hand2",
                  command=lambda: self._open_social_connect(
                      user, LIGHT, DGRAY, GRAY, PINK, WHITE)).pack(side="left", padx=4)

    def open_edit_profile(self, user, profile_page, LIGHT, DGRAY, GRAY, PINK, WHITE):
        win = tk.Toplevel(self.root)
        win.title("Edit Profil")
        win.geometry("360x400")
        win.config(bg=WHITE)
        tk.Label(win, text="Edit Profil", font=("Segoe UI", 14, "bold"), bg=WHITE).pack(pady=14)

        fields = {}
        for label, key in [("Nama Lengkap", "fullname"), ("Username", "username"),
                            ("Email", "email"), ("Bio", "bio")]:
            tk.Label(win, text=label, bg=WHITE, font=("Segoe UI", 9)).pack(anchor="w", padx=20)
            e = tk.Entry(win, width=38, font=("Segoe UI", 10))
            e.insert(0, user.get(key, ""))
            e.pack(padx=20, pady=(2, 8))
            fields[key] = e

        tk.Label(win, text="Password Baru (kosongkan jika tidak diubah)",
                 bg=WHITE, font=("Segoe UI", 9)).pack(anchor="w", padx=20)
        pwd_entry = tk.Entry(win, width=38, show="*", font=("Segoe UI", 10))
        pwd_entry.pack(padx=20, pady=(2, 12))

        def save():
            new_username = fields["username"].get().strip()
            old_username = user["username"]
            if new_username != old_username and new_username in self.users:
                messagebox.showerror("Error", "Username sudah digunakan", parent=win)
                return
            new_pwd = pwd_entry.get().strip()
            if new_pwd:
                if len(new_pwd) < 8 or not any(c.isdigit() for c in new_pwd):
                    messagebox.showerror("Error",
                        "Password minimal 8 karakter dan mengandung angka", parent=win)
                    return
                user["password"] = new_pwd

            user["fullname"] = fields["fullname"].get().strip()
            user["email"]    = fields["email"].get().strip()
            user["bio"]      = fields["bio"].get().strip()

            if new_username != old_username:
                user["username"] = new_username
                self.users[new_username] = user
                del self.users[old_username]
                for p in self.posts:
                    if p["username"] == old_username:
                        p["username"] = new_username
                for s in self.stories:
                    if s["username"] == old_username:
                        s["username"] = new_username

            win.destroy()
            self._render_profile(profile_page, user, LIGHT, DGRAY, GRAY, PINK, WHITE)
            messagebox.showinfo("Sukses", "Profil berhasil diperbarui!")

        tk.Button(win, text="Simpan", bg=PINK, font=("Segoe UI", 10, "bold"),
                  bd=0, padx=14, pady=6, command=save).pack()


    def _open_social_connect(self, user, LIGHT, DGRAY, GRAY, PINK, WHITE):
        win = tk.Toplevel(self.root)
        win.title("Social Connect")
        win.geometry("480x420")
        win.config(bg=LIGHT)
        self._build_social_connect_page(win, user, LIGHT, DGRAY, GRAY, PINK, WHITE)


