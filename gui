        post_lf = tk.Frame(post_panel, bg=LIGHT)
        post_lf.pack(fill="both", expand=True)
        post_canvas, post_inner = self.make_scrollable(post_lf, LIGHT)

        def show_tag_posts(tag):
            active_tag[0] = tag
            for w in post_inner.winfo_children():
                w.destroy()
            tag_post_ids = self.communities.get(tag, [])
            tag_posts = [p for p in self.posts if p["id"] in tag_post_ids]
            tag_posts_sorted = sorted(tag_posts, key=self.feed_score, reverse=True)
            tk.Label(post_inner, text=f"#{tag}  —  {len(tag_posts_sorted)} postingan",
                     font=("Segoe UI", 11, "bold"), bg=LIGHT, fg=DGRAY).pack(
                         anchor="w", pady=(4, 8))
            if not tag_posts_sorted:
                tk.Label(post_inner, text="Belum ada postingan dengan hashtag ini.",
                         font=("Segoe UI", 10), bg=LIGHT, fg=GRAY).pack(pady=20)
                return
            for p in tag_posts_sorted:
                row = tk.Frame(post_inner, bg=WHITE, pady=8, padx=10,
                               highlightthickness=1, highlightbackground="#eee")
                row.pack(fill="x", pady=3)
                u_data   = self.users.get(p["username"], {})
                fullname = u_data.get("fullname", p["username"])
                initials = "".join(w[0].upper() for w in fullname.split()[:2])
                h = tk.Frame(row, bg=WHITE)
                h.pack(fill="x")
                tk.Label(h, text=initials, font=("Segoe UI", 9, "bold"),
                         bg=PINK, fg=DGRAY, width=3).pack(side="left")
                tk.Label(h, text=f"  @{p['username']}", font=("Segoe UI", 9, "bold"),
                         bg=WHITE, fg=DGRAY).pack(side="left")
                score = self.feed_score(p)
                tk.Label(h, text=f"  🔥{score:.0f}", font=("Segoe UI", 8),
                         bg=WHITE, fg="#e57a8a").pack(side="left")
                tk.Label(h, text=p["ts"], font=("Segoe UI", 8), bg=WHITE, fg=GRAY).pack(side="right")
                post_text = p["text"]
                tk.Label(row, text=post_text, font=("Segoe UI", 10),
                         bg=WHITE, fg=DGRAY, wraplength=360, justify="left").pack(
                             anchor="w", pady=(4, 2))
                stat = tk.Frame(row, bg=WHITE)
                stat.pack(anchor="w")
                tk.Label(stat, text=f"❤️ {len(p['likes'])}  💬 {len(p.get('comments',[]))}",
                         font=("Segoe UI", 8), bg=WHITE, fg=GRAY).pack(side="left")

        def refresh_tag_list(filter_text=""):
            for w in tag_list_frame.winfo_children():
                if not isinstance(w, tk.Label) or w.cget("font") != "Segoe UI 10 bold":
                    w.destroy()
            sorted_tags = sorted(
                self.communities.keys(),
                key=lambda t: len(self.communities[t]),
                reverse=True
            )
            if filter_text:
                sorted_tags = [t for t in sorted_tags if filter_text.lower() in t]
            for tag in sorted_tags[:20]:
                count = len(self.communities[tag])
                btn = tk.Button(tag_list_frame,
                                text=f"#{tag}  ({count})",
                                font=("Segoe UI", 9), bg=WHITE, bd=0,
                                anchor="w", padx=8, pady=3, cursor="hand2",
                                command=lambda t=tag: show_tag_posts(t))
                btn.pack(fill="x")
            if not sorted_tags:
                tk.Label(tag_list_frame, text="Belum ada #hashtag",
                         font=("Segoe UI", 8), bg=WHITE, fg=GRAY).pack(pady=8, padx=8)

        def on_search(*args):
            q = search_var.get().lstrip("#").strip()
            if search_entry.is_showing_placeholder:
                q = ""
            refresh_tag_list(q)

        search_var.trace_add("write", on_search)

        def do_search(event=None):
            q = self.get_entry_value(search_entry).lstrip("#").strip()
            if q:
                refresh_tag_list(q)
                if q in self.communities:
                    show_tag_posts(q)

        search_entry.bind("<Return>", do_search)
        tk.Button(top, text="Cari", font=("Segoe UI", 9), bg=PINK, fg=DGRAY,
                  bd=0, padx=8, pady=3, command=do_search).pack(side="left", padx=(6, 0))

        refresh_tag_list()
        if self.communities:
            first_tag = sorted(self.communities.keys(),
                               key=lambda t: len(self.communities[t]), reverse=True)[0]
            show_tag_posts(first_tag)
        else:
            tk.Label(post_inner, text="Post dengan #hashtag ",
                     font=("Segoe UI", 10), bg=LIGHT, fg=GRAY).pack(pady=30)

    def _build_social_connect_page(self, parent, viewer, LIGHT, DGRAY, GRAY, PINK, WHITE):
        for w in parent.winfo_children():
            w.destroy()

        tk.Label(parent, text="Social Connect", font=("Segoe UI", 13, "bold"),
                 bg=LIGHT, fg=DGRAY).pack(pady=12)

        lf = tk.Frame(parent, bg=LIGHT)
        lf.pack(fill="both", expand=True, padx=16)
        _, inner = self.make_scrollable(lf, LIGHT)

        def refresh():
            for w in inner.winfo_children():
                w.destroy()
            other_users = [u for uname, u in self.users.items()
                           if uname != viewer["username"]]
            if not other_users:
                tk.Label(inner, text="Belum ada pengguna lain.",
                         font=("Segoe UI", 10), bg=LIGHT, fg=GRAY).pack(pady=20)
                return
            for u in other_users:
                row = tk.Frame(inner, bg=WHITE, pady=8, padx=10,
                               highlightthickness=1, highlightbackground="#eee")
                row.pack(fill="x", pady=3)
                initials = "".join(w2[0].upper() for w2 in u["fullname"].split()[:2])
                left = tk.Frame(row, bg=WHITE)
                left.pack(side="left", fill="x", expand=True)
                tk.Label(left, text=initials, font=("Segoe UI", 10, "bold"),
                         bg=PINK, fg=DGRAY, width=3).pack(side="left")
                info = tk.Frame(left, bg=WHITE)
                info.pack(side="left", padx=8)
                tk.Label(info, text=u["fullname"], font=("Segoe UI", 10, "bold"),
                         bg=WHITE, fg=DGRAY).pack(anchor="w")
                tk.Label(info, text=f"@{u['username']}  •  {u.get('role','User')}",
                         font=("Segoe UI", 8), bg=WHITE, fg=GRAY).pack(anchor="w")
                u_posts = len([p for p in self.posts if p["username"] == u["username"]])
                u_flwrs = sum(1 for f in self.follows.values() if u["username"] in f)
                tk.Label(info, text=f"📝 {u_posts} post  •  👥 {u_flwrs} followers",
                         font=("Segoe UI", 8), bg=WHITE, fg=GRAY).pack(anchor="w")

                is_flw = self.is_following(viewer["username"], u["username"])
                btn_text = "✓ Following" if is_flw else "+ Follow"
                btn_bg   = "#d0f0d0" if is_flw else PINK

                def make_follow_toggle(target_uname=u["username"]):
                    def do():
                        self.toggle_follow(viewer["username"], target_uname)
                        refresh()
                    return do

                tk.Button(row, text=btn_text, font=("Segoe UI", 8, "bold"),
                          bg=btn_bg, fg=DGRAY, bd=0, padx=8, pady=4,
                          cursor="hand2", command=make_follow_toggle()).pack(side="right")

        refresh()
        return inner

