    # ─── NAV SWITCH ──────────────────────────────────────────────────────────

    def nav_switch(self, pages, index, nav_btns, PINK, DPINK, refresh_activity_fn=None):
        for page in pages:
            page.pack_forget()
        pages[index].pack(fill="both", expand=True)
        if index == 2 and refresh_activity_fn:
            refresh_activity_fn()
        for i, (frm, ico, lbl) in enumerate(nav_btns):
            if i == index:
                frm.config(bg=PINK); ico.config(bg=PINK); lbl.config(bg=PINK, fg="#333")
            else:
                frm.config(bg="white"); ico.config(bg="white"); lbl.config(bg="white", fg="#888")

    # ─── STORY ───────────────────────────────────────────────────────────────

    def open_add_story(self, refresh_fn):
        win = tk.Toplevel(self.root)
        win.title("Tambah Story")
        win.geometry("360x200")
        win.config(bg="white")
        tk.Label(win, text="Isi Story kamu:", font=("Segoe UI", 10), bg="white").pack(pady=10)
        entry = tk.Text(win, width=40, height=4, font=("Segoe UI", 10))
        entry.pack(padx=16)

        def submit():
            text = entry.get("1.0", tk.END).strip()
            if not text:
                messagebox.showerror("Error", "Story tidak boleh kosong", parent=win)
                return
            filtered, words = self.content_filter(text)
            if words:
                self.log_violation(self.current_user["username"], words, "Story")
            self.stories.append({
                "id":       self.next_story_id,
                "username": self.current_user["username"],
                "text":     filtered,
                "ts":       self.now_str(),
            })
            self.next_story_id += 1
            win.destroy()
            refresh_fn()

        tk.Button(win, text="Posting Story", bg="#ffc0cb",
                  font=("Segoe UI", 10, "bold"), command=submit).pack(pady=10)

    # ─── POST ─────────────────────────────────────────────────────────────────

    def create_post(self, user, refresh_fn):
        text = self.post_entry.get().strip()
        if not text:
            return
        filtered, words = self.content_filter(text)
        if words:
            self.log_violation(user["username"], words, "Post")
        new_post = {
            "id":       self.next_post_id,
            "username": user["username"],
            "text":     filtered,
            "likes":    [],
            "comments": [],
            "ts":       self.now_str(),
        }
        self.posts.append(new_post)
        self.register_hashtags(new_post)
        self.next_post_id += 1
        self.post_entry.delete(0, tk.END)
        refresh_fn()
        self.canvas_ref.update_idletasks()
        self.canvas_ref.yview_moveto(0.0)

