                 font=("Segoe UI", 20, "bold"), bg="white").pack(pady=30)
        sf = tk.Frame(page, bg="white")
        sf.pack()
        for label, fn in [("Total User", lambda: len(self.users)),
                           ("Total Post",  lambda: len(self.posts)),
                           ("Total Story", lambda: len(self.stories))]:
            box = tk.Frame(sf, bg="#ffc0cb", width=140, height=80)
            box.pack(side="left", padx=16, pady=10)
