# moderator.py
import tkinter as tk
import data
from admin import AdminDashboard  # Re-use visual komponen halaman dari Admin

class ModeratorDashboard:
    def __init__(self, root, user, app_instance):
        self.root = root
        self.user = user
        self.app = app_instance
        self.admin_view = AdminDashboard(root, user, app_instance)

    def show(self):
        self.app.clear_window()
        sidebar = self.app.create_sidebar("MODERATOR")
        content = tk.Frame(self.root, bg="white")
        content.pack(fill="both", expand=True)

        # Moderator tidak memiliki fitur kelola user ("users")
        pages = {
            "home":    self.admin_view._admin_page_home(content, self.user),
            "posts":   self.admin_view._admin_page_mod_list(content, "post"),
            "stories": self.admin_view._admin_page_mod_list(content, "story"),
            "log":     self.admin_view._admin_page_violation_log(content),
        }

        def switch_page(name):
            for p in pages.values():
                p.pack_forget()
            pages[name].pack(fill="both", expand=True)

        self.app.add_sidebar_btn(sidebar, "🏠  Beranda",       lambda: switch_page("home"))
        self.app.add_sidebar_btn(sidebar, "📝  Review Post",   lambda: switch_page("posts"))
        self.app.add_sidebar_btn(sidebar, "📖  Review Story",  lambda: switch_page("stories"))
        self.app.add_sidebar_btn(sidebar, "🚨  Log Pelanggaran", lambda: switch_page("log"))

        tk.Button(sidebar, text="Logout", bg="tomato", fg="white",
                  font=("Segoe UI", 9, "bold"), bd=0, cursor="hand2",
                  command=self.app.show_login).pack(side="bottom", pady=20, padx=20, fill="x")

        switch_page("home")
