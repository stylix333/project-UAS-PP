            ("🚨", "Pelanggaran",  3),
            ("📊", "Analitik",     4),
        ]

        def mod_nav_switch(index):
            for page in pages:
                page.pack_forget()
            pages[index].pack(fill="both", expand=True)
            for i, (frm, ico, lbl) in enumerate(nav_btns):
                if i == index:
                    frm.config(bg=PINK); ico.config(bg=PINK); lbl.config(bg=PINK, fg="#333")
                else:
                    frm.config(bg=WHITE); ico.config(bg=WHITE); lbl.config(bg=WHITE, fg=GRAY)

        for icon, label, idx in nav_items:
            btn_frame = tk.Frame(navbar, bg=WHITE, cursor="hand2")
            btn_frame.pack(side="left", expand=True, fill="both")
            ico = tk.Label(btn_frame, text=icon, font=("Segoe UI", 14), bg=WHITE)
            ico.pack(pady=(6, 0))
            lbl = tk.Label(btn_frame, text=label, font=("Segoe UI", 8), bg=WHITE, fg=GRAY)
            lbl.pack()
            for w in (btn_frame, ico, lbl):
                w.bind("<Button-1>", lambda e, i=idx: mod_nav_switch(i))
            nav_btns.append((btn_frame, ico, lbl))

        mod_nav_switch(0)

