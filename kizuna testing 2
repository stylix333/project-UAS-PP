                              command=make_edit_cmt()).pack(side="left")
                    tk.Button(action_f, text="Hapus", bg="tomato", fg="white",
                              font=("Segoe UI", 7), bd=0, padx=4,
                              command=make_del_cmt()).pack(side="left", padx=(2, 0))

