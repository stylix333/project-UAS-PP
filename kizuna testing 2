        win.title("Komentar")
        win.geometry("420x480")
        win.config(bg=WHITE)
        tk.Label(win, text="Komentar", font=("Segoe UI", 13, "bold"), bg=WHITE).pack(pady=10)

        lf = tk.Frame(win, bg=WHITE)
        lf.pack(fill="both", expand=True, padx=16)
        _, c_inner = self.make_scrollable(lf, WHITE)

        def render_comments():
            for w in c_inner.winfo_children():
                w.destroy()
            if not post.get("comments"):
                tk.Label(c_inner, text="Belum ada komentar.",
                         bg=WHITE, fg=GRAY, font=("Segoe UI", 9)).pack(pady=10)
                return
            for cm in post["comments"]:
                row = tk.Frame(c_inner, bg=LIGHT, pady=6, padx=8,
                               highlightthickness=1, highlightbackground="#eee")
                row.pack(fill="x", pady=2)
                meta_row = tk.Frame(row, bg=LIGHT)
                meta_row.pack(fill="x")
                cmt_ts_disp = cm["ts"] + ("  ✏️" if cm.get("edited") else "")
                tk.Label(meta_row, text=f"@{cm['username']}  •  {cmt_ts_disp}",
                         font=("Segoe UI", 8), bg=LIGHT, fg=GRAY).pack(side="left", anchor="w")

                if cm["username"] == viewer["username"]:
                    def make_edit_cmt(comment=cm):
                        def do():
                            def on_save(new_text):
                                filtered, words = self.content_filter(new_text)
                                if words:
                                    self.log_violation(viewer["username"], words, "Komentar (Edit)")
                                comment["text"]   = filtered
                                comment["edited"] = True
                                render_comments()
                                cmt_btn.config(text=f"💬 {len(post.get('comments', []))}")
                                refresh_activity_fn()
                            self.open_edit_dialog("Edit Komentar", comment["text"], on_save, win)
                        return do

                    def make_del_cmt(cid=cm["id"]):
                        def do():
                            post["comments"] = [x for x in post["comments"] if x["id"] != cid]
                            render_comments()
                            cmt_btn.config(text=f"💬 {len(post.get('comments', []))}")
                            refresh_activity_fn()
                        return do

                    action_f = tk.Frame(meta_row, bg=LIGHT)
                    action_f.pack(side="right")
                    tk.Button(action_f, text="✏️ Edit", bg=LIGHT, fg=DGRAY,
