                           if uname != viewer["username"]]
            if not other_users:
                tk.Label(inner, text="Belum ada pengguna lain.",
                         font=("Segoe UI", 10), bg=LIGHT, fg=GRAY).pack(pady=20)
                return
            for u in other_users:
                row = tk.Frame(inner, bg=WHITE, pady=8, padx=10,
                               highlightthickness=1, highlightbackground="#eee")
                row.pack(fill="x", pady=3)
                initials = "".join(w2[0].upper() for w2 in u["fullname"].split()[:2])
                left = tk.Frame(row, bg=WHITE)
                left.pack(side="left", fill="x", expand=True)
                tk.Label(left, text=initials, font=("Segoe UI", 10, "bold"),
                         bg=PINK, fg=DGRAY, width=3).pack(side="left")
                info = tk.Frame(left, bg=WHITE)
                info.pack(side="left", padx=8)
                tk.Label(info, text=u["fullname"], font=("Segoe UI", 10, "bold"),
                         bg=WHITE, fg=DGRAY).pack(anchor="w")
                tk.Label(info, text=f"@{u['username']}  •  {u.get('role','User')}",
                         font=("Segoe UI", 8), bg=WHITE, fg=GRAY).pack(anchor="w")
                u_posts = len([p for p in self.posts if p["username"] == u["username"]])
                u_flwrs = sum(1 for f in self.follows.values() if u["username"] in f)
                tk.Label(info, text=f"📝 {u_posts} post  •  👥 {u_flwrs} followers",
                         font=("Segoe UI", 8), bg=WHITE, fg=GRAY).pack(anchor="w")
                is_flw   = self.is_following(viewer["username"], u["username"])
                btn_text = "✓ Following" if is_flw else "+ Follow"
                btn_bg   = "#d0f0d0" if is_flw else PINK

                def make_follow_toggle(target_uname=u["username"]):
                    def do():
                        self.toggle_follow(viewer["username"], target_uname)
                        refresh()
                    return do

                tk.Button(row, text=btn_text, font=("Segoe UI", 8, "bold"),
                          bg=btn_bg, fg=DGRAY, bd=0, padx=8, pady=4,
                          cursor="hand2", command=make_follow_toggle()).pack(side="right")

        refresh()
        return inner

