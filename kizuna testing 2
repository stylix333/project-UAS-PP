    def create_card(self, width=380, height=420):
        card = tk.Frame(self.root, bg="white", bd=1, relief="solid")
        card.place(relx=0.5, rely=0.5, anchor="center", width=width, height=height)
        return card

    def now_str(self):
        return datetime.now().strftime("%d %b %Y %H:%M")

    def content_filter(self, text):
        result = text
        found  = []
        for kata in self.banned_words:
            teks_lower = result.lower()
            if kata in teks_lower:
                found.append(kata)
                teks_baru = ""
                i = 0
                while i < len(result):
                    if result[i:i + len(kata)].lower() == kata:
                        teks_baru += "***"
                        i += len(kata)
                    else:
                        teks_baru += result[i]
                        i += 1
                result = teks_baru
        return result, found

    def log_violation(self, username, words, tipe):
        for w in words:
            self.violation_log.append({
                "username": username,
                "kata":     w,
                "tipe":     tipe,
                "ts":       self.now_str(),
            })

    def feed_score(self, post):
        likes    = len(post.get("likes", []))
        comments = len(post.get("comments", []))
        raw_ts = post.get("raw_ts") or post.get("ts", "")
        raw_ts = raw_ts.replace(" (diedit)", "").strip()
        recency = 0
        for fmt in ("%d %b %Y %H:%M", "%d-%m-%Y %H:%M", "%Y-%m-%d %H:%M"):
            try:
                ts_dt     = datetime.strptime(raw_ts, fmt)
                age_hours = max((datetime.now() - ts_dt).total_seconds() / 3600, 0.01)
                recency   = 10 / math.log(age_hours + math.e)
                break
            except ValueError:
                continue
        return (likes * 3) + (comments * 5) + recency

    def extract_hashtags(self, text):
        import re
        return [tag.lower() for tag in re.findall(r"#(\w+)", text)]

    def register_hashtags(self, post):
        for tag in self.extract_hashtags(post["text"]):
            self.communities.setdefault(tag, [])
            if post["id"] not in self.communities[tag]:
                self.communities[tag].append(post["id"])

    def unregister_hashtags_for_post(self, post_id):
        for tag in list(self.communities.keys()):
            if post_id in self.communities[tag]:
                self.communities[tag].remove(post_id)

    def is_following(self, follower, target):
        return target in self.follows.get(follower, set())

    def toggle_follow(self, follower, target):
        self.follows.setdefault(follower, set())
        if target in self.follows[follower]:
            self.follows[follower].discard(target)
        else:
            self.follows[follower].add(target)

    # ─── PLACEHOLDER HELPER ──────────────────────────────────────────────────

    def add_placeholder(self, entry, placeholder, is_password=False):
        entry.placeholder            = placeholder
        entry.is_password            = is_password
        entry.is_showing_placeholder = True
        entry.config(fg="gray")
        entry.insert(0, placeholder)

        def on_focus_in(event):
            if entry.is_showing_placeholder:
                entry.delete(0, tk.END)
                entry.config(fg="black")
                if is_password:
                    entry.config(show="*")
                entry.is_showing_placeholder = False

        def on_focus_out(event):
            if entry.get() == "":
                entry.insert(0, placeholder)
                entry.config(fg="gray")
                if is_password:
                    entry.config(show="")
                entry.is_showing_placeholder = True

        entry.bind("<FocusIn>",  on_focus_in)
        entry.bind("<FocusOut>", on_focus_out)

    def get_entry_value(self, entry):
        if entry.is_showing_placeholder:
            return ""
        return entry.get()

    # ─── SCROLLABLE FRAME HELPER ─────────────────────────────────────────────

    def make_scrollable(self, parent, bg="#f9f9f9"):
        canvas = tk.Canvas(parent, bg=bg, bd=0, highlightthickness=0)
        sb     = tk.Scrollbar(parent, orient="vertical", command=canvas.yview)
        inner  = tk.Frame(canvas, bg=bg)
        inner.bind("<Configure>",
                   lambda e: canvas.configure(scrollregion=canvas.bbox("all")))
        win_id = canvas.create_window((0, 0), window=inner, anchor="nw")
        canvas.configure(yscrollcommand=sb.set)
        canvas.bind("<Configure>", lambda e: canvas.itemconfig(win_id, width=e.width))
        canvas.pack(side="left", fill="both", expand=True)
        sb.pack(side="right", fill="y")
        return canvas, inner

