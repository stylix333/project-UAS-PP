        content_frame.pack(fill="both", expand=True, padx=16, pady=(4, 8))
        _, content_inner = self.make_scrollable(content_frame, LIGHT)

        active_tab = [0]

        def render_tab():
            for w in content_inner.winfo_children():
                w.destroy()
            if active_tab[0] == 0:
                items = [p for p in self.posts if p["username"] == user["username"]]
                items = sorted(items, key=lambda x: x["id"], reverse=True)
                if not items:
                    tk.Label(content_inner, text="Belum ada postingan.",
                             font=("Segoe UI", 10), bg=LIGHT, fg=GRAY).pack(pady=20)
                for p in items:
                    row = tk.Frame(content_inner, bg=WHITE, pady=8, padx=10,
                                   highlightthickness=1, highlightbackground="#eee")
                    row.pack(fill="x", pady=3)
                    top_r = tk.Frame(row, bg=WHITE)
                    top_r.pack(fill="x")
                    tk.Label(top_r, text=p["ts"] + (" ✏️ diedit" if p.get("edited") else ""),
                             font=("Segoe UI", 8), bg=WHITE, fg=GRAY).pack(side="left")
                    tk.Label(top_r, text=f"❤️{len(p['likes'])} 💬{len(p.get('comments',[]))}",
                             font=("Segoe UI", 8), bg=WHITE, fg=GRAY).pack(side="right")
                    tk.Label(row, text=p["text"], font=("Segoe UI", 10),
                             bg=WHITE, fg=DGRAY, wraplength=380, justify="left").pack(anchor="w", pady=(4, 2))

                    def make_edit_p(pp=p):
                        def do():
                            def on_save(new_text):
                                filtered, words = self.content_filter(new_text)
                                if words:
                                    self.log_violation(user["username"], words, "Post (Edit)")
                                self.unregister_hashtags_for_post(pp["id"])
                                pp["text"]   = filtered
                                pp["edited"] = True
                                self.register_hashtags(pp)
                                if refresh_feed_fn:
                                    refresh_feed_fn()
                                render_tab()
                            self.open_edit_dialog("Edit Postingan", pp["text"], on_save)
                        return do

                    def make_del_p(pp=p):
                        def do():
                            if messagebox.askyesno("Hapus Post", "Hapus postingan ini?"):
                                self.unregister_hashtags_for_post(pp["id"])
                                self.posts = [x for x in self.posts if x["id"] != pp["id"]]
                                if refresh_feed_fn:
                                    refresh_feed_fn()
                                render_tab()
                        return do

                    act_r = tk.Frame(row, bg=WHITE)
                    act_r.pack(anchor="e")
                    tk.Button(act_r, text="✏️ Edit", bg=LIGHT, fg=DGRAY,
                              font=("Segoe UI", 8), bd=0, padx=4,
                              command=make_edit_p()).pack(side="left")
                    tk.Button(act_r, text="🗑 Hapus", bg="tomato", fg="white",
                              font=("Segoe UI", 8), bd=0, padx=4,
                              command=make_del_p()).pack(side="left", padx=(4, 0))
            else:
                items = [s for s in self.stories if s["username"] == user["username"]]
                items = sorted(items, key=lambda x: x["id"], reverse=True)
                if not items:
                    tk.Label(content_inner, text="Belum ada story.",
                             font=("Segoe UI", 10), bg=LIGHT, fg=GRAY).pack(pady=20)
                for s in items:
                    row = tk.Frame(content_inner, bg=WHITE, pady=8, padx=10,
                                   highlightthickness=1, highlightbackground="#eee")
                    row.pack(fill="x", pady=3)
                    tk.Label(row, text=s["ts"], font=("Segoe UI", 8), bg=WHITE, fg=GRAY).pack(anchor="w")
                    tk.Label(row, text=s["text"], font=("Segoe UI", 10),
                             bg=WHITE, fg=DGRAY, wraplength=380, justify="left").pack(anchor="w", pady=(4, 2))

                    def make_del_s(ss=s):
                        def do():
                            if messagebox.askyesno("Hapus Story", "Hapus story ini?"):
                                self.stories = [x for x in self.stories if x["id"] != ss["id"]]
                                render_tab()
                        return do

                    tk.Button(row, text="🗑 Hapus", bg="tomato", fg="white",
                              font=("Segoe UI", 8), bd=0, padx=4,
                              command=make_del_s()).pack(anchor="e")

        def switch_tab(idx, btn_post, btn_story):
            active_tab[0] = idx
            if idx == 0:
                btn_post.config(bg=PINK, relief="flat")
                btn_story.config(bg=WHITE, relief="groove")
            else:
                btn_story.config(bg=PINK, relief="flat")
                btn_post.config(bg=WHITE, relief="groove")
            render_tab()

        btn_post  = tk.Button(tab_frame, text="📝 Postingan", font=("Segoe UI", 9),
                              bg=PINK, bd=0, relief="flat", padx=10, pady=4, cursor="hand2")
        btn_story = tk.Button(tab_frame, text="📖 Story", font=("Segoe UI", 9),
                              bg=WHITE, bd=1, relief="groove", padx=10, pady=4, cursor="hand2")
        btn_post.pack(side="left", padx=(0, 4))
        btn_story.pack(side="left")
        btn_post.config( command=lambda: switch_tab(0, btn_post, btn_story))
        btn_story.config(command=lambda: switch_tab(1, btn_post, btn_story))

        render_tab()

