    def _build_community_page(self, parent, user, LIGHT, DGRAY, GRAY, PINK, WHITE):
        tk.Label(parent, text="Hashtag", font=("Segoe UI", 14, "bold"),
                 bg=LIGHT, fg=DGRAY).pack(pady=14)

        top = tk.Frame(parent, bg=LIGHT)
        top.pack(fill="x", padx=16, pady=(0, 8))

        search_var   = tk.StringVar()
        search_entry = tk.Entry(top, textvariable=search_var, font=("Segoe UI", 10),
                                bd=1, relief="solid", width=20)
        search_entry.pack(side="left", ipady=3)
        self.add_placeholder(search_entry, "Cari #hashtag...")

        active_tag  = [None]
        right_panel = tk.Frame(parent, bg=LIGHT)
        right_panel.pack(fill="both", expand=True, padx=16)

        tag_list_frame = tk.Frame(right_panel, bg=WHITE, width=160)
        tag_list_frame.pack(side="left", fill="y", padx=(0, 8))
        tag_list_frame.pack_propagate(False)
        tk.Label(tag_list_frame, text="Trending #", font=("Segoe UI", 10, "bold"),
                 bg=WHITE, fg=DGRAY).pack(pady=8, padx=8, anchor="w")

        post_panel = tk.Frame(right_panel, bg=LIGHT)
        post_panel.pack(side="left", fill="both", expand=True)

        post_lf = tk.Frame(post_panel, bg=LIGHT)
        post_lf.pack(fill="both", expand=True)
        post_canvas, post_inner = self.make_scrollable(post_lf, LIGHT)

        def show_tag_posts(tag):
            active_tag[0] = tag
            for w in post_inner.winfo_children():
                w.destroy()
            tag_post_ids     = self.communities.get(tag, [])
            tag_posts        = [p for p in self.posts if p["id"] in tag_post_ids]
            tag_posts_sorted = sorted(tag_posts, key=self.feed_score, reverse=True)
            tk.Label(post_inner, text=f"#{tag}  —  {len(tag_posts_sorted)} postingan",
                     font=("Segoe UI", 11, "bold"), bg=LIGHT, fg=DGRAY).pack(
                         anchor="w", pady=(4, 8))
            if not tag_posts_sorted:
                tk.Label(post_inner, text="Belum ada postingan dengan hashtag ini.",
                         font=("Segoe UI", 10), bg=LIGHT, fg=GRAY).pack(pady=20)
                return
            for p in tag_posts_sorted:
                row = tk.Frame(post_inner, bg=WHITE, pady=8, padx=10,
                               highlightthickness=1, highlightbackground="#eee")
                row.pack(fill="x", pady=3)
                u_data   = self.users.get(p["username"], {})
                fullname = u_data.get("fullname", p["username"])
                initials = "".join(ww[0].upper() for ww in fullname.split()[:2])
                h = tk.Frame(row, bg=WHITE)
                h.pack(fill="x")
                tk.Label(h, text=initials, font=("Segoe UI", 9, "bold"),
                         bg=PINK, fg=DGRAY, width=3).pack(side="left")
                tk.Label(h, text=f"  @{p['username']}", font=("Segoe UI", 9, "bold"),
                         bg=WHITE, fg=DGRAY).pack(side="left")
                score = self.feed_score(p)
                tk.Label(h, text=f"  🔥{score:.0f}", font=("Segoe UI", 8),
                         bg=WHITE, fg="#e57a8a").pack(side="left")
                tk.Label(h, text=p["ts"] + (" ✏️" if p.get("edited") else ""),
                         font=("Segoe UI", 8), bg=WHITE, fg=GRAY).pack(side="right")
                tk.Label(row, text=p["text"], font=("Segoe UI", 10),
                         bg=WHITE, fg=DGRAY, wraplength=360, justify="left").pack(
                             anchor="w", pady=(4, 2))
                stat = tk.Frame(row, bg=WHITE)
                stat.pack(anchor="w")
                tk.Label(stat, text=f"❤️ {len(p['likes'])}  💬 {len(p.get('comments', []))}",
                         font=("Segoe UI", 8), bg=WHITE, fg=GRAY).pack(side="left")

        def refresh_tag_list(filter_text=""):
            for w in tag_list_frame.winfo_children():
                if isinstance(w, tk.Label) and w.cget("text") == "Trending #":
                    continue
                if not isinstance(w, tk.Label):
                    w.destroy()
                elif w.cget("text") != "Trending #":
                    w.destroy()
            sorted_tags = sorted(self.communities.keys(),
                                 key=lambda t: len(self.communities[t]), reverse=True)
            if filter_text:
                sorted_tags = [t for t in sorted_tags if filter_text.lower() in t]
            for tag in sorted_tags[:20]:
                count = len(self.communities[tag])
                btn = tk.Button(tag_list_frame, text=f"#{tag}  ({count})",
                                font=("Segoe UI", 9), bg=WHITE, bd=0,
                                anchor="w", padx=8, pady=3, cursor="hand2",
                                command=lambda t=tag: show_tag_posts(t))
                btn.pack(fill="x")
            if not sorted_tags:
                tk.Label(tag_list_frame, text="Belum ada #hashtag",
                         font=("Segoe UI", 8), bg=WHITE, fg=GRAY).pack(pady=8, padx=8)

        def on_search(*args):
            q = search_var.get().lstrip("#").strip()
            if search_entry.is_showing_placeholder:
                q = ""
            refresh_tag_list(q)

        search_var.trace_add("write", on_search)

        def do_search(event=None):
            q = self.get_entry_value(search_entry).lstrip("#").strip()
            if q:
                refresh_tag_list(q)
                if q in self.communities:
                    show_tag_posts(q)

        search_entry.bind("<Return>", do_search)
        tk.Button(top, text="Cari", font=("Segoe UI", 9), bg=PINK, fg=DGRAY,
                  bd=0, padx=8, pady=3, command=do_search).pack(side="left", padx=(6, 0))

        refresh_tag_list()
        if self.communities:
            first_tag = sorted(self.communities.keys(),
                               key=lambda t: len(self.communities[t]), reverse=True)[0]
            show_tag_posts(first_tag)
        else:
            tk.Label(post_inner, text="Post dengan #hashtag akan muncul di sini.",
                     font=("Segoe UI", 10), bg=LIGHT, fg=GRAY).pack(pady=30)

