        sec2 = tk.Frame(inner, bg=LIGHT)
        sec2.pack(fill="x", padx=16, pady=(0, 14))
        tk.Label(sec2, text="#️⃣  Trending Hashtag",
                 font=("Segoe UI", 11, "bold"), bg=LIGHT, fg=DGRAY).pack(anchor="w", pady=(0, 6))
        sorted_tags = sorted(self.communities.keys(),
                             key=lambda t: len(self.communities[t]), reverse=True)
        tag_colors  = ["#e57a8a", "#f4a261", "#2ec4b6", "#a8dadc", "#457b9d",
                       "#e9c46a", "#264653", "#e76f51", "#6a4c93", "#1982c4"]
        max_count   = len(self.communities[sorted_tags[0]]) if sorted_tags else 1
        for idx, tag in enumerate(sorted_tags[:8]):
            count   = len(self.communities[tag])
            bar_pct = count / max_count if max_count > 0 else 0
            col     = tag_colors[idx % len(tag_colors)]
            row = tk.Frame(sec2, bg=WHITE, pady=6, padx=10,
                           highlightthickness=1, highlightbackground="#eee")
