        sorted_posts = sorted(self.posts, key=self.feed_score, reverse=True)
        max_score    = self.feed_score(sorted_posts[0]) if sorted_posts else 1

        for rank, p in enumerate(sorted_posts[:8], 1):
            score   = self.feed_score(p)
            bar_pct = score / max_score if max_score > 0 else 0
            row = tk.Frame(sec, bg=WHITE, pady=6, padx=10,
                           highlightthickness=1, highlightbackground="#eee")
            row.pack(fill="x", pady=2)
            rank_clr = "#e57a8a" if rank == 1 else ("#f4a261" if rank == 2 else ("#2ec4b6" if rank == 3 else GRAY))
