    def _build_mod_post_page(self, parent, user, LIGHT, DGRAY, GRAY, PINK, WHITE):
        # Header
        hdr = tk.Frame(parent, bg=WHITE, pady=10)
        hdr.pack(fill="x")
        tk.Label(hdr, text="📝  Review Postingan",
                 font=("Segoe UI", 14, "bold"), bg=WHITE, fg=DGRAY).pack(side="left", padx=16)
        total_lbl = tk.Label(hdr, text="", font=("Segoe UI", 9), bg=WHITE, fg=GRAY)
        total_lbl.pack(side="left")
        tk.Frame(parent, bg="#eeeeee", height=1).pack(fill="x")

        lf = tk.Frame(parent, bg=LIGHT)
        lf.pack(fill="both", expand=True, padx=12, pady=8)
        _, inner = self.make_scrollable(lf, LIGHT)

        def refresh():
            for w in inner.winfo_children():
                w.destroy()
            total_lbl.config(text=f"({len(self.posts)} postingan)")
            if not self.posts:
                tk.Label(inner, text="Tidak ada postingan.", bg=LIGHT, fg=GRAY,
                         font=("Segoe UI", 10)).pack(pady=30)
                return
            # sort by newest
            items = sorted(self.posts, key=lambda p: p.get("id", 0), reverse=True)
            for p in items:
                card = tk.Frame(inner, bg=WHITE, pady=10, padx=12,
                                highlightthickness=1, highlightbackground="#eeeeee")
                card.pack(fill="x", pady=(0, 6))

                # Header row
                top = tk.Frame(card, bg=WHITE)
                top.pack(fill="x")
                u_data   = self.users.get(p["username"], {})
                fullname = u_data.get("fullname", p["username"])
                initials = "".join(ww[0].upper() for ww in fullname.split()[:2])
                tk.Label(top, text=initials, font=("Segoe UI", 10, "bold"),
                         bg=PINK, fg=DGRAY, width=3).pack(side="left")
                tk.Label(top, text=f"  {fullname}  (@{p['username']})",
                         font=("Segoe UI", 10, "bold"), bg=WHITE, fg=DGRAY).pack(side="left")
                tk.Label(top, text=p["ts"] + (" ✏️" if p.get("edited") else ""),
                         font=("Segoe UI", 8), bg=WHITE, fg=GRAY).pack(side="left", padx=6)

                # Stats badge
                stats_f = tk.Frame(top, bg=WHITE)
                stats_f.pack(side="right")
                tk.Label(stats_f, text=f"❤️ {len(p['likes'])}",
                         font=("Segoe UI", 8), bg="#fce4ec", fg="#c62828", padx=4).pack(side="left", padx=2)
                tk.Label(stats_f, text=f"💬 {len(p.get('comments', []))}",
                         font=("Segoe UI", 8), bg="#e8f5e9", fg="#2e7d32", padx=4).pack(side="left", padx=2)
                score = self.feed_score(p)
                tk.Label(stats_f, text=f"🔥 {score:.0f}",
                         font=("Segoe UI", 8), bg="#fff3e0", fg="#e65100", padx=4).pack(side="left", padx=2)

                # Post text
                tk.Label(card, text=p["text"], font=("Segoe UI", 10),
                         bg=WHITE, fg=DGRAY, wraplength=560, justify="left").pack(
                             anchor="w", pady=(8, 6))

                # Hashtag chips
                tags = self.extract_hashtags(p["text"])
                if tags:
                    tag_row = tk.Frame(card, bg=WHITE)
                    tag_row.pack(anchor="w", pady=(0, 4))
                    for tag in tags:
                        tk.Label(tag_row, text=f"#{tag}", font=("Segoe UI", 8),
