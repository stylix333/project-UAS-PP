    def _add_post_card(self, post, viewer, WHITE, LIGHT, GRAY, DGRAY, PINK,
                       refresh_feed_fn, refresh_activity_fn):
        card = tk.Frame(self.feed_inner, bg=WHITE, pady=10, padx=12,
                        highlightthickness=1, highlightbackground="#eeeeee")
        card.pack(fill="x", pady=(0, 8))

        header = tk.Frame(card, bg=WHITE)
        header.pack(fill="x")

        u_data   = self.users.get(post["username"], {})
        fullname = u_data.get("fullname", post["username"])
        initials = "".join(w[0].upper() for w in fullname.split()[:2])

        tk.Label(header, text=initials, font=("Segoe UI", 10, "bold"),
                 bg=PINK, fg=DGRAY, width=3).pack(side="left")
        tk.Label(header, text=f"  {post['username']}",
                 font=("Segoe UI", 10, "bold"), bg=WHITE, fg=DGRAY).pack(side="left")
        ts_display = post["ts"] + ("  ✏️ diedit" if post.get("edited") else "")
        tk.Label(header, text=f"  {ts_display}",
                 font=("Segoe UI", 8), bg=WHITE, fg=GRAY).pack(side="left")

        if post["username"] == viewer["username"]:
            def make_delete(pid=post["id"]):
                def do():
                    if messagebox.askyesno("Hapus Post",
                                           "Apakah kamu yakin ingin menghapus postingan ini?"):
                        self.unregister_hashtags_for_post(pid)
                        self.posts = [p for p in self.posts if p["id"] != pid]
                        refresh_feed_fn()
                return do

            def make_edit_post(p=post):
                def do():
                    def on_save(new_text):
                        filtered, words = self.content_filter(new_text)
                        if words:
                            self.log_violation(viewer["username"], words, "Post (Edit)")
                        self.unregister_hashtags_for_post(p["id"])
                        p["text"]   = filtered
                        p["edited"] = True
                        self.register_hashtags(p)
                        refresh_feed_fn()
                    self.open_edit_dialog("Edit Postingan", p["text"], on_save)
                return do

            act_btns = tk.Frame(header, bg=WHITE)
            act_btns.pack(side="right")
            tk.Button(act_btns, text="✏️", font=("Segoe UI", 9), bg=WHITE,
                      bd=0, fg=DGRAY, cursor="hand2",
                      command=make_edit_post()).pack(side="left")
            tk.Button(act_btns, text="🗑", font=("Segoe UI", 9), bg=WHITE,
                      bd=0, fg="tomato", cursor="hand2",
                      command=make_delete()).pack(side="left")

        post_text_var = tk.StringVar(value=post["text"])
        post_label = tk.Label(card, textvariable=post_text_var, font=("Segoe UI", 11),
                              bg=WHITE, fg=DGRAY, wraplength=500, justify="left")
        post_label.pack(anchor="w", pady=(8, 4))

        action_row = tk.Frame(card, bg=WHITE)
        action_row.pack(anchor="w", fill="x")

        liked    = viewer["username"] in post["likes"]
        like_var = tk.StringVar(value=f"{'❤️' if liked else '♡'} {len(post['likes'])}")
        like_btn = tk.Button(action_row, textvariable=like_var,
                             font=("Segoe UI", 10), bg=WHITE, bd=0,
                             fg="#e57a8a" if liked else GRAY, cursor="hand2")
        like_btn.pack(side="left", padx=(0, 8))

        def toggle_like(p=post, var=like_var, btn=like_btn):
            uname = viewer["username"]
            if uname in p["likes"]:
                p["likes"].remove(uname)
                var.set(f"♡ {len(p['likes'])}")
                btn.config(fg=GRAY)
            else:
                p["likes"].append(uname)
                var.set(f"❤️ {len(p['likes'])}")
                btn.config(fg="#e57a8a")
            refresh_activity_fn()

        like_btn.config(command=toggle_like)

        cmt_btn = tk.Button(action_row, text=f"💬 {len(post.get('comments', []))}",
                            font=("Segoe UI", 10), bg=WHITE, bd=0,
                            fg=GRAY, cursor="hand2")
        cmt_btn.pack(side="left")
        cmt_btn.config(command=lambda p=post, btn=cmt_btn: self.open_comments(
            p, btn, viewer, WHITE, LIGHT, GRAY, DGRAY, PINK, refresh_activity_fn))

