    # ─── NAV SWITCH ──────────────────────────────────────────────────────────

    def nav_switch(self, pages, index, nav_btns, PINK, DPINK,
                   refresh_activity_fn=None, **kwargs):
        for page in pages:
            page.pack_forget()
        pages[index].pack(fill="both", expand=True)

        if index == 3 and refresh_activity_fn:
            refresh_activity_fn()

        if index == 4:
            page4  = kwargs.get("page4")
            user   = kwargs.get("user")
            LIGHT  = kwargs.get("LIGHT", "#f9f9f9")
            DGRAY  = kwargs.get("DGRAY", "#333333")
            GRAY   = kwargs.get("GRAY", "#888888")
            PINK2  = kwargs.get("PINK2", "#ffc0cb")
            WHITE  = kwargs.get("WHITE", "#ffffff")
            rf     = kwargs.get("rf")
            if page4 and user:
                self._render_profile(page4, user, LIGHT, DGRAY, GRAY, PINK2, WHITE, rf)

        for i, (frm, ico, lbl) in enumerate(nav_btns):
            if i == index:
                frm.config(bg=PINK); ico.config(bg=PINK); lbl.config(bg=PINK, fg="#333")
            else:
                frm.config(bg="white"); ico.config(bg="white"); lbl.config(bg="white", fg="#888")

