                     bg=WHITE, fg=GRAY).pack(anchor="w")
            right_f = tk.Frame(row, bg=WHITE)
            right_f.pack(side="left", fill="x", expand=True, padx=(8, 0))
            bar_bg = tk.Frame(right_f, bg="#f0f0f0", height=16)
            bar_bg.pack(fill="x", pady=4)
