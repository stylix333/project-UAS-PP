                # Action buttons
                act = tk.Frame(card, bg=WHITE)
                act.pack(anchor="e")

                def make_warn(pid=p["id"], uname=p["username"]):
                    def do():
                        messagebox.showwarning("Peringatan Dikirim",
                            f"Peringatan telah dikirim ke @{uname}.\n"
                            f"Post ID: {pid}")
                        self.log_violation(uname, ["[mod-warning]"], "Post (Peringatan Mod)")
                    return do

                def make_del(pid=p["id"]):
                    def do():
                        if messagebox.askyesno("Hapus Post", "Hapus postingan ini?"):
                            self.unregister_hashtags_for_post(pid)
                            self.posts = [x for x in self.posts if x["id"] != pid]
